SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional — secondary Supabase project for BridgeMatch-Content blog posts.
# When set, Telegram approve/reject for posts tagged brand='bridgematch' is
# routed to this project instead of the primary one. Leave blank if all
# content lives in a single project.
SUPABASE_URL_BRIDGEMATCH=
SUPABASE_SERVICE_KEY_BRIDGEMATCH=
# ── CONTENT GENERATION MODEL (Claude) ──────────────────────
# CONTENT GENERATION (social post copy + Lot of the Day copy) now runs on
# Claude Sonnet with extended thinking, for quality/diversity. REQUIRED for
# generation; if unset, generation silently falls back to Gemini Flash below.
CLAUDE_API_KEY=
# Optional overrides:
#   CLAUDE_MODEL            — defaults to claude-sonnet-4-6
#   CLAUDE_THINKING_BUDGET  — extended-thinking token budget (default 8000; 0 disables)
CLAUDE_MODEL=
CLAUDE_THINKING_BUDGET=
# ── LLM PROVIDER (Gemini — outbound/classify/enrich + generation fallback) ──
# Choose ONE. Priority order: GEMINI_API_KEY > OPENROUTER_API_KEY.
# GEMINI_API_KEY   — Google AI Studio (free tier, gemini-2.0-flash)
# OPENROUTER_API_KEY — OpenRouter (paid, same gemini-2.0-flash model)
# Still used by all NON-generation LLM calls (outbound, classification, etc.).
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MAKE_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REVIEW_UI_PASSWORD=
# Required by lib/review-api.js — external blog/guide generators POST drafts to
# /api/review with `Authorization: Bearer ${REVIEW_API_KEY}`. Without this the
# endpoint returns 500. Generate a long random string and set the same value
# on whatever service is calling /api/review.
REVIEW_API_KEY=
# Per-brand Facebook Page credentials (used by lib/publish.js)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_BRIDGEMATCH_PAGE_ID=
FB_BRIDGEMATCH_PAGE_TOKEN=
PORT=3000

# Dashboard auth — scrypt-hashed password (Phase A).
# Generate with:  node scripts/gen-dashboard-hash.js
# Then set both values in Railway environment variables.
# REVIEW_UI_PASSWORD is kept as a plaintext fallback for local dev only.
DASHBOARD_PASSWORD_HASH=
DASHBOARD_PASSWORD_SALT=

# ─────────────────────────────────────────────────────────────
# NEW — required for the Growth Brain outbound build.
# Create the account, then paste the key into .env (NOT this file).
# .env is git-ignored — never commit it. These move to Railway env
# vars in Growth Brain build Phase A.
# ─────────────────────────────────────────────────────────────

# Resend — outbound email send (Phase B)
RESEND_API_KEY=

# Contact enrichment (Phase B) — use ONE of these
HUNTER_API_KEY=
# APOLLO_API_KEY=

# Supabase service-role key — privileged writes for the new outbound
# tables, if the anon key's row-level security is insufficient
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────
# PHASE D — Broker + auction-house importers + Performance tab.
# ─────────────────────────────────────────────────────────────

# FCA Connect Register V0.1 API auth. Required by lib/sales-brain/fca-fetch.js
# (both fetchBulkRegister and fetchFirmByFrn). Without these, the broker
# importer (lib/sales-brain/import-brokers.js) cannot enrich a bare FRN
# CSV via the Connect API — it requires a pre-downloaded rich bulk
# extract passed via `--source-csv <path>` instead.
#
# Register for a free key (lead time 1-2 working days):
#   https://register.fca.org.uk/Re/
FCA_AUTH_EMAIL=
FCA_AUTH_KEY=

# Optional override — direct URL to the FCA bulk-data extract. The FCA
# rotates the file location per release; check the public-data page for
# the current link:
#   https://www.fca.org.uk/firms/financial-services-register/access-data
FCA_BULK_EXTRACT_URL=

# Per-track Resend FROM addresses. Phase B set RESEND_FROM_LENDER
# directly in Railway env; Phase D adds the two new tracks. Architect
# 2026-05-25: outreach.bridgematch.co.uk is `not_started` in Resend, so
# the broker default falls back to simon@auctionbrain.co.uk for now.
# Flip RESEND_FROM_BROKER when bridgematch DNS finishes warming — no
# code change needed.
RESEND_FROM_BROKER=
RESEND_FROM_AUCTION_HOUSE=

# ─────────────────────────────────────────────────────────────
# PHASE G-3 — Make boost integration (paid Facebook amplification).
# Three env vars, ALL three required before the boost loop activates.
# See .ruflo/phase-g3-design.md §4 and .ruflo/phase-g3-ops.md §3.
#
# DUAL-WRITE WARNING. MAKE_WEBHOOK_SECRET + MAKE_CALLBACK_SECRET each
# need to be set in TWO places:
#   1. Railway env (here) — used by lib/social-engine/webhook-auth.js
#   2. Make-side — used by the two scenarios (ub-social-boost and
#      ub-social-boost-reconcile) when they compute / verify HMAC.
# Recommended Make-side storage: a Data Store named `cb-secrets` with
# one record per secret, referenced from scenario steps via
# {{ env.MAKE_WEBHOOK_SECRET }} / {{ env.MAKE_CALLBACK_SECRET }}.
# Rotating either secret means updating BOTH Railway and Make sides
# in lockstep, or the next webhook fails HMAC verification.
#
# SIMON-ACTION ITEMS before the operator runs scripts/make/provision.js:
#   1. Refresh the FB OAuth connection in Make UI — connection id
#      6444829 expires 2026-06-05. Re-authorize with EXPANDED scopes:
#      add `ads_management` + `ads_read` on top of the existing Pages
#      scopes. The Marketing API rejects Create Campaign/AdSet/Ad
#      without these.
#   2. Confirm the FB ad account currency is GBP (Ads Manager → Account
#      Settings). If USD, the Make AdSet module needs a pence→cents FX
#      conversion before activation.
#   3. Fund the FB ad account (£60/mo nominal max at £2/day × 30).
# ─────────────────────────────────────────────────────────────

# Public URL of the ub-social-boost Make scenario webhook. Captured
# from scripts/make/provision.js stdout after the scenario is created.
# When UNSET, requestBoost falls back to PR2 behaviour — inserts the
# boost_runs row at status='pending' and returns without firing any
# webhook. Production-safe default until Make is provisioned.
MAKE_BOOST_WEBHOOK_URL=

# Shared secret for OUTBOUND ContentBrain -> Make webhook signing.
# CB computes X-CB-Signature: sha256=<hex(HMAC-SHA256(body, secret))>;
# the Make scenario step 2 (SetVariables2 HMAC compute) recomputes and
# rejects mismatches. Generate with: openssl rand -base64 64
# Set on BOTH Railway env AND Make (Data Store record / scenario var).
MAKE_WEBHOOK_SECRET=

# Shared secret for INBOUND Make -> ContentBrain callback signing. Make
# computes X-Make-Signature with this; CB's webhook-auth.verifyInbound
# recomputes and timing-safe-compares. Distinct secret from
# MAKE_WEBHOOK_SECRET so a leak of one does NOT compromise the other
# direction. Generate with: openssl rand -base64 64
# Set on BOTH Railway env AND Make (Data Store record / scenario var).
MAKE_CALLBACK_SECRET=
